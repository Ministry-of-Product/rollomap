POSTGRES_USER=rollomap
POSTGRES_PASSWORD=rollomap
POSTGRES_DB=rollomap
POSTGRES_PORT=5432

DATABASE_URL=postgres://rollomap:rollomap@localhost:5432/rollomap

API_PORT=4000
WEBAPP_PORT=5173

# Default workspace used by the local single-user setup
WORKSPACE_ID=00000000-0000-0000-0000-000000000001

# Optional fallbacks used only when the workspace profile (managed via
# PUT /api/profile or the MCP update_profile tool) has nothing set for the
# corresponding field. Leave blank to rely on the profile.
#
# USER_INTERESTS=comma,separated,interests   # falls back for profile.interests
# INGEST_SKIP_EMAIL=you@example.com          # falls back for the ingest skill's --skip-email
# INGEST_SKIP_NAME=Your Name                 # falls back for the ingest skill's --skip-name
