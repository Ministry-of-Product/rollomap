{
  "name": "@rollomap/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test:reset": "../../scripts/reset-test-db.sh",
    "pretest": "npm run test:reset",
    "test": "DATABASE_URL=${TEST_DATABASE_URL:-postgres://rollomap:rollomap@localhost:5432/rollomap_test} node --import tsx --test $(find src -name '*.test.ts')"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
