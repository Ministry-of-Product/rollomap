{
  "name": "rollomap",
  "private": true,
  "version": "0.1.0",
  "description": "RolloMap - private relationship intelligence (local v1)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "dev:api": "npm --workspace @rollomap/api run dev",
    "dev:webapp": "npm --workspace @rollomap/webapp run dev",
    "dev:mcp": "npm --workspace @rollomap/mcp-server run dev",
    "mcp:launch": "scripts/launch-mcp.sh",
    "seed": "npm --workspace @rollomap/api run seed",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ministry-of-Product/rollomap.git"
  },
  "homepage": "https://github.com/Ministry-of-Product/rollomap#readme",
  "bugs": {
    "url": "https://github.com/Ministry-of-Product/rollomap/issues"
  }
}
